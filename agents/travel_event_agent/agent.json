{
  "name": "travel_event_agent",
  "description": "여행지 기준 지역 축제와 문화행사를 추천하는 에이전트",
  "role": "지역 축제 / 문화행사 추천",
  "inputs": [
    "destination",
    "location",
    "days",
    "user_request"
  ],
  "outputs": [
    "summary",
    "event_items",
    "event_findings",
    "recommendations",
    "debug_info"
  ],
  "data_sources": [
    "tour_api",
    "mock_fallback"
  ],
  "version": "0.1.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "destination": {
        "type": "string",
        "description": "Preferred travel destination."
      },
      "location": {
        "type": "string",
        "description": "Fallback travel location."
      },
      "days": {
        "type": "integer",
        "description": "Trip duration in days."
      },
      "user_request": {
        "type": "string",
        "description": "Original user travel request."
      }
    },
    "additionalProperties": true
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "agent": {
        "type": "string"
      },
      "summary": {
        "type": "string"
      },
      "destination": {
        "type": "string"
      },
      "data_source": {
        "type": "string",
        "enum": [
          "tour_api",
          "mock_fallback"
        ]
      },
      "event_items": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "event_findings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "recommendations": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "debug_info": {
        "type": "object"
      }
    },
    "required": [
      "agent",
      "summary",
      "destination",
      "data_source",
      "event_items",
      "event_findings",
      "recommendations",
      "debug_info"
    ]
  },
  "entrypoint": "main.py",
  "function": "run"
}
