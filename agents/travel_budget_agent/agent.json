{
  "name": "travel_budget_agent",
  "description": "사용자의 여행 목적지, 출발지, 기간, 예산 수준, 숙박 여부, 식사 횟수, 장거리/현지 교통 규칙을 기준으로 국내여행 예상 예산을 계산하는 규칙형 에이전트입니다.",
  "role": "여행 예산 / 비용 계산",
  "inputs": [
    "destination",
    "origin",
    "days",
    "budget_level",
    "requested_features"
  ],
  "outputs": [
    "summary",
    "estimated_total_krw",
    "budget_breakdown",
    "assumptions",
    "saving_tips",
    "warnings",
    "debug_info"
  ],
  "data_sources": [
    "rule_based_budget"
  ],
  "env_vars": [],
  "version": "0.2.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "destination": {
        "type": "string",
        "description": "여행 목적지입니다."
      },
      "origin": {
        "type": "string",
        "description": "출발지입니다."
      },
      "days": {
        "type": "integer",
        "description": "여행 일수입니다."
      },
      "budget_level": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ],
        "description": "예산 수준입니다."
      },
      "requested_features": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "destination",
      "days",
      "budget_level"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "agent": {
        "type": "string"
      },
      "data_source": {
        "type": "string",
        "enum": [
          "rule_based_budget"
        ]
      },
      "destination": {
        "type": "string"
      },
      "origin": {
        "type": "string"
      },
      "days": {
        "type": "integer"
      },
      "duration_label": {
        "type": "string"
      },
      "budget_level": {
        "type": "string"
      },
      "lodging_required": {
        "type": "boolean"
      },
      "lodging_nights": {
        "type": "integer"
      },
      "meal_count": {
        "type": "integer"
      },
      "estimated_total_krw": {
        "type": "integer"
      },
      "budget_breakdown": {
        "type": "object",
        "properties": {
          "long_distance_transport": {
            "type": "integer"
          },
          "local_transport": {
            "type": "integer"
          },
          "transport": {
            "type": "integer"
          },
          "lodging": {
            "type": "integer"
          },
          "food": {
            "type": "integer"
          },
          "tour_event": {
            "type": "integer"
          },
          "buffer": {
            "type": "integer"
          }
        },
        "required": [
          "long_distance_transport",
          "local_transport",
          "transport",
          "lodging",
          "food",
          "tour_event",
          "buffer"
        ]
      },
      "assumptions": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "saving_tips": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "debug_info": {
        "type": "object"
      }
    },
    "required": [
      "agent",
      "data_source",
      "estimated_total_krw",
      "budget_breakdown",
      "assumptions",
      "saving_tips",
      "warnings",
      "debug_info"
    ]
  },
  "entrypoint": "main.py",
  "function": "run"
}
