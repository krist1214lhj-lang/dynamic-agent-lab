{
  "name": "travel_transport_agent",
  "description": "사용자의 출발지, 목적지, 여행 기간을 바탕으로 ODsay 대중교통 길찾기 또는 안전한 규칙 기반 fallback 교통 계획을 반환하는 에이전트입니다.",
  "role": "도시 간 이동 / 현지 교통 계획",
  "inputs": [
    "origin",
    "destination",
    "location",
    "days",
    "user_request"
  ],
  "outputs": [
    "summary",
    "data_source",
    "transport_profile",
    "transport_overview",
    "routes",
    "transport_tips",
    "debug_info"
  ],
  "data_sources": [
    "odsay_api",
    "rule_based_fallback",
    "mock_fallback"
  ],
  "env_vars": [
    "ODSAY_API_KEY"
  ],
  "fallback_policy": "교통 단독 요청에서는 ODSAY_API_KEY가 있으면 ODsay를 시도하고, 키가 없거나 호출이 실패하면 mock_fallback을 유지합니다. 다중 기능 전체 워크플로우에서는 로컬/Vercel 응답 안정성을 위해 mock_fallback을 유지합니다. 제주/섬 지역은 ODsay보다 island_air_sea 규칙을 우선 적용하며 data_source는 rule_based_fallback으로 반환합니다. API 키 원문은 응답과 debug_info에 노출하지 않습니다.",
  "island_policy": "destination이 제주이거나 transport_profile이 island_air_sea인 경우 항공편/선박 중심 규칙을 우선 적용합니다.",
  "version": "0.1.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "origin": {
        "type": "string",
        "description": "출발 도시 또는 지역"
      },
      "destination": {
        "type": "string",
        "description": "도착 도시 또는 여행 목적지"
      },
      "days": {
        "type": "integer",
        "description": "여행 일수"
      },
      "travel_style": {
        "type": "string",
        "description": "선호 이동 방식 또는 여행 스타일"
      },
      "user_request": {
        "type": "string",
        "description": "사용자의 원문 여행 요청"
      }
    },
    "required": []
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "agent": {
        "type": "string"
      },
      "data_source": {
        "type": "string",
        "enum": [
          "odsay_api",
          "rule_based_fallback",
          "mock_fallback"
        ]
      },
      "transport_profile": {
        "type": "string",
        "enum": [
          "public_transport",
          "island_air_sea"
        ]
      },
      "summary": {
        "type": "string"
      },
      "transport_overview": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "main_transport": {
            "type": "string"
          },
          "local_transport": {
            "type": "string"
          },
          "estimated_travel_time": {
            "type": "string"
          }
        }
      },
      "routes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "method": {
              "type": "string"
            },
            "estimated_time": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            },
            "route_type": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "total_time_minutes": {
              "type": ["integer", "null"]
            },
            "payment": {
              "type": ["integer", "null"]
            },
            "transfer_count": {
              "type": "integer"
            },
            "steps_summary": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "transport_tips": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "risks": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "next_agents": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "entrypoint": "main.py",
  "function": "run"
}
