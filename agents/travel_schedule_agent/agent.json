{
  "name": "travel_schedule_agent",
  "description": "사용자의 여행 조건과 planning, transport, budget, food, event, tour, destination, weather 에이전트 결과를 참고해 시간대별 최종 여행 일정표를 구성하는 규칙형 일정 컴포저입니다.",
  "role": "통합 여행 일정표 생성",
  "inputs": [
    "destination",
    "origin",
    "days",
    "budget_level",
    "requested_features",
    "agent_results"
  ],
  "outputs": [
    "summary",
    "schedule_summary",
    "duration_strategy",
    "daily_itinerary",
    "itinerary",
    "integration_notes",
    "warnings",
    "debug_info"
  ],
  "data_sources": [
    "integrated_rule_schedule",
    "rule_based_schedule"
  ],
  "env_vars": [],
  "version": "0.2.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "destination": {
        "type": "string",
        "description": "여행 목적지입니다."
      },
      "origin": {
        "type": "string",
        "description": "출발지입니다."
      },
      "days": {
        "type": "integer",
        "description": "여행 일수입니다."
      },
      "budget_level": {
        "type": "string",
        "description": "예산 수준입니다. 예: low, medium, high"
      },
      "requested_features": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "agent_results": {
        "type": "array",
        "items": {
          "type": "object"
        }
      }
    },
    "required": [
      "destination",
      "days"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "agent": {
        "type": "string"
      },
      "data_source": {
        "type": "string",
        "enum": [
          "integrated_rule_schedule",
          "rule_based_schedule"
        ]
      },
      "destination": {
        "type": "string"
      },
      "origin": {
        "type": "string"
      },
      "days": {
        "type": "integer"
      },
      "duration_label": {
        "type": "string"
      },
      "duration_strategy": {
        "type": "object"
      },
      "daily_itinerary": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "day": {
              "type": "integer"
            },
            "title": {
              "type": "string"
            },
            "time_blocks": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          },
          "required": [
            "day",
            "title",
            "time_blocks"
          ]
        }
      },
      "schedule_summary": {
        "type": "string"
      },
      "integration_notes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "debug_info": {
        "type": "object"
      }
    },
    "required": [
      "agent",
      "data_source",
      "daily_itinerary",
      "schedule_summary",
      "duration_strategy",
      "integration_notes",
      "warnings",
      "debug_info"
    ]
  },
  "entrypoint": "main.py",
  "function": "run"
}
